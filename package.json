{
  "name": "deprovision-ephemeral-environment",
  "version": "1.0.4",
  "description": "GitHub Action to deprovision an ephemeral environment in Octopus Deploy",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node24 --outfile=dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "clean": "rimraf dist"
  },
  "keywords": [
    "github-action",
    "octopus-deploy",
    "ephemeral-environment"
  ],
  "author": "Octopus Deploy",
  "license": "Apache-2.0",
  "devDependencies": {
    "@types/jest": "29.5.14",
    "@types/node": "24.12.2",
    "@typescript-eslint/eslint-plugin": "8.59.2",
    "@typescript-eslint/parser": "8.59.2",
    "esbuild": "0.28.0",
    "eslint": "8.57.1",
    "jest": "29.7.0",
    "jest-junit": "16.0.0",
    "msw": "2.12.14",
    "prettier": "3.8.3",
    "rimraf": "6.1.3",
    "ts-jest": "29.4.9",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "@actions/core": "3.0.0",
    "@octopusdeploy/api-client": "3.10.2",
    "axios": "^1.17.0"
  }
}

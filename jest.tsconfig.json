{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "target": "ES2022",
        "esModuleInterop": true,
        "module": "CommonJS",
        "moduleResolution": "node",
        "lib": [
            "es2022"
        ],
        "strict": true,
        "allowJs": true
    },
    "include": [
        "src/**/__tests__/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}
